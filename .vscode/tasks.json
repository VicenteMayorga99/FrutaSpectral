      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Arduino: Compilar y cargar pruebas",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "arduino-cli compile --fqbn esp32:esp32:esp32 .; if ($LASTEXITCODE -eq 0) { arduino-cli upload -p COM3 --fqbn esp32:esp32:esp32 . }"
      ],
      "options": {
        "cwd": "${workspaceFolder}/pruebas"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
